# Required — OpenAI (Whisper STT + TTS)
OPENAI_API_KEY=sk-proj-your-key-here

# Optional — weather widget. Any city name accepted by wttr.in. Leave empty to disable.
TARS_LOCATION=

# Optional — Home Assistant smart-home gestures. Leave both empty to disable;
# palm/fist gestures will then silently no-op.
HA_URL=
HA_TOKEN=
